{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://northstarbuild.dev/schemas/mbf-governance.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "governance", "confidence"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "governance": {
      "type": "object",
      "required": ["profile"],
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["starter", "professional", "enterprise"]
        }
      },
      "additionalProperties": false
    },
    "confidence": {
      "type": "object",
      "required": ["factors", "thresholds"],
      "properties": {
        "factors": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["weight"],
            "properties": {
              "weight": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "description": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "thresholds": {
          "type": "object",
          "required": ["high", "medium", "low", "uncertain"],
          "properties": {
            "high": { "type": "number", "minimum": 0, "maximum": 1 },
            "medium": { "type": "number", "minimum": 0, "maximum": 1 },
            "low": { "type": "number", "minimum": 0, "maximum": 1 },
            "uncertain": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "anchors": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "https://northstarbuild.dev/schemas/anchors.schema.json#/definitions/anchorRule" }
      }
    },
    "autonomy": {
      "type": "object",
      "properties": {
        "default_level": { "type": "number", "minimum": 1, "maximum": 6 },
        "escalation_paths": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["condition", "action"],
            "properties": {
              "condition": { "type": "string" },
              "action": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "tools": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "hooks": {
      "type": "object",
      "required": ["profile"],
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["minimal", "standard", "strict"]
        },
        "disabled": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "budgets": {
      "type": "object",
      "properties": {
        "per_run_usd": { "type": "number", "minimum": 0 },
        "per_project_usd": { "type": "number", "minimum": 0 },
        "per_run_tokens": { "type": "number", "minimum": 0 },
        "per_project_tokens": { "type": "number", "minimum": 0 },
        "warn_at": { "type": "number", "minimum": 0, "maximum": 1 },
        "currency": { "type": "string" }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "object",
      "properties": {
        "allow": { "type": "array", "items": { "type": "string" } },
        "deny": { "type": "array", "items": { "type": "string" } },
        "destructive_gates": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "routing": {
      "type": "object",
      "properties": {
        "orchestrator": { "type": "string" },
        "subtask": { "type": "string" },
        "cheap": { "type": "string" },
        "fast": { "type": "boolean" },
        "effort": { "type": "string" }
      },
      "additionalProperties": false
    },
    "sinks": {
      "type": "object",
      "properties": {
        "webhooks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["url"],
            "properties": {
              "url": { "type": "string" },
              "enabled": { "type": "boolean" },
              "redactPayload": { "type": "boolean" },
              "allowInsecure": { "type": "boolean" },
              "allowPrivate": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        },
        "allowlist": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
