{
  "name": "@nsb/cli",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "northstarbuild": "dist/index.js",
    "nsb": "dist/index.js"
  },
  "files": [
    "dist/**",
    "templates/**"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --banner \"#!/usr/bin/env node\"",
    "test": "vitest run",
    "test:e2e": "vitest run --dir tests/e2e",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@nsb/anchors": "workspace:*",
    "@nsb/core": "workspace:*",
    "@nsb/schema": "workspace:*",
    "commander": "^12.0.0",
    "inquirer": "^10.2.0",
    "yaml": "^2.5.1"
  }
}
